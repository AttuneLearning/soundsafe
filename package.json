{
  "name": "soundsafe",
  "version": "0.0.0",
  "private": true,
  "description": "Soundsafe — sound-desensitization PWA (workspace root)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:packages": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "dev": "pnpm --filter @soundsafe/consumer-app dev",
    "wasm:build": "wasm-pack build packages/rust-core --target web --out-dir pkg",
    "wasm:test": "wasm-pack test --node packages/rust-core",
    "cargo:check": "cargo check --workspace",
    "cargo:test": "cargo nextest run --workspace",
    "schema:check": "pnpm --filter @soundsafe/roadmap-schema generate:check"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4"
  }
}
