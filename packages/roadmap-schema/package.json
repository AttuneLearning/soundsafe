{
  "name": "@soundsafe/roadmap-schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zod schemas for Roadmap, Step, Transform, TransformParams, Manifest. Generated from sfx-pack-manifest.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "generate": "node ./scripts/generate.mjs",
    "generate:check": "node ./scripts/generate.mjs --check"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "json-schema-to-zod": "^2.4.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4"
  }
}
