{
  "name": "@soundsafe/consumer-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Soundsafe consumer PWA — the shipping v1 React app.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@soundsafe/audio-graph-ts": "workspace:*",
    "@soundsafe/entitlement": "workspace:*",
    "@soundsafe/pack-client": "workspace:*",
    "@soundsafe/platform": "workspace:*",
    "@soundsafe/roadmap-schema": "workspace:*",
    "@soundsafe/storage": "workspace:*",
    "@soundsafe/ui-kit": "workspace:*",
    "rust-core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "happy-dom": "^14.12.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
